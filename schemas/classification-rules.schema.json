{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacelber.github.io/mtgo-data/schemas/classification-rules.schema.json",
  "title": "Versioned constructed classification rules",
  "x-schema-version": "1.0.0",
  "type": "object",
  "required": ["schema_version", "format", "archetypes"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "format": {"$ref": "#/$defs/id"},
    "archetypes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/archetype"}}
  },
  "additionalProperties": false,
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "priority": {"type": "integer", "minimum": 0},
    "subtype": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {"id": {"$ref": "#/$defs/id"}, "name": {"type": "string", "minLength": 1}},
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": ["card"],
      "properties": {
        "card": {"type": "string", "minLength": 1},
        "zone": {"enum": ["any", "main", "side"]},
        "min_count": {"type": "integer", "minimum": 0},
        "max_count": {"type": "integer", "minimum": 0},
        "exact_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false,
      "not": {
        "anyOf": [
          {"required": ["exact_count", "min_count"]},
          {"required": ["exact_count", "max_count"]}
        ]
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "priority", "conditions"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "priority": {"$ref": "#/$defs/priority"},
        "subtype_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "conditions": {
          "type": "object",
          "required": ["all"],
          "properties": {"all": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/condition"}}},
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "archetype": {
      "type": "object",
      "required": ["id", "name", "priority", "rules"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "name": {"type": "string", "minLength": 1},
        "priority": {"$ref": "#/$defs/priority"},
        "subtypes": {"type": "array", "items": {"$ref": "#/$defs/subtype"}},
        "rules": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rule"}}
      },
      "additionalProperties": false
    }
  }
}
