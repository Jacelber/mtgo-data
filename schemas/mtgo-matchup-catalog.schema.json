{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacelber.github.io/mtgo-data/schemas/mtgo-matchup-catalog.schema.json",
  "title": "MTGO matchup catalog",
  "x-schema-version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "format",
    "source",
    "generated",
    "latest_complete_week",
    "min_sample_hint",
    "ranges"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schemaVersion"
    },
    "format": {
      "enum": ["standard", "modern"]
    },
    "source": {
      "const": "mtgo"
    },
    "generated": {
      "type": "string",
      "minLength": 1
    },
    "latest_complete_week": {
      "type": "string",
      "format": "date"
    },
    "min_sample_hint": {
      "type": "integer",
      "minimum": 1
    },
    "hierarchical": {
      "const": true
    },
    "ranges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/range"
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "format": {
          "const": "standard"
        },
        "ranges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/standardRange"
          }
        }
      },
      "not": {
        "required": ["hierarchical"]
      }
    },
    {
      "properties": {
        "format": {
          "const": "modern"
        },
        "ranges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modernRange"
          }
        }
      },
      "required": ["hierarchical"]
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "range": {
      "type": "object",
      "required": [
        "file",
        "type",
        "start",
        "end",
        "weeks",
        "archetypes",
        "counted_matches"
      ],
      "properties": {
        "file": {
          "type": "string",
          "pattern": "^matchup_[0-9]+w\\.json$"
        },
        "type": {
          "type": "string",
          "pattern": "^[0-9]+w$"
        },
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": "string",
          "format": "date"
        },
        "weeks": {
          "type": "integer",
          "minimum": 1
        },
        "archetypes": {
          "type": "integer",
          "minimum": 0
        },
        "leaves": {
          "type": "integer",
          "minimum": 0
        },
        "counted_matches": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "standardRange": {
      "allOf": [
        {
          "$ref": "#/$defs/range"
        },
        {
          "not": {
            "required": ["leaves"]
          }
        }
      ]
    },
    "modernRange": {
      "allOf": [
        {
          "$ref": "#/$defs/range"
        },
        {
          "required": ["leaves"]
        }
      ]
    }
  }
}
