{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacelber.github.io/mtgo-data/schemas/mtgo-matchup-catalog.schema.json",
  "title": "Legacy Standard MTGO matchup catalog",
  "x-schema-version": "1.0.0",
  "type": "object",
  "required": ["format", "source", "generated", "latest_complete_week", "min_sample_hint", "ranges"],
  "properties": {
    "format": {"const": "standard"}, "source": {"const": "mtgo"}, "generated": {"type": "string", "minLength": 1},
    "latest_complete_week": {"type": "string", "format": "date"}, "min_sample_hint": {"type": "integer", "minimum": 1},
    "ranges": {"type": "array", "items": {"type": "object", "required": ["file", "type", "start", "end", "weeks", "archetypes", "counted_matches"], "properties": {
      "file": {"type": "string", "pattern": "^matchup_[0-9]+w\\.json$"}, "type": {"type": "string", "pattern": "^[0-9]+w$"},
      "start": {"type": "string", "format": "date"}, "end": {"type": "string", "format": "date"}, "weeks": {"type": "integer", "minimum": 1},
      "archetypes": {"type": "integer", "minimum": 0}, "counted_matches": {"type": "integer", "minimum": 0}
    }, "additionalProperties": false}}
  },
  "additionalProperties": false
}
