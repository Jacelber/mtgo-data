{
  "schema_version": "1.0.0",
  "profile": "legacy-standard-mtgo-public-json",
  "output_schema_version_embedded": false,
  "note": "Compatibility contract for existing unversioned public output. Producer migration to embedded schema_version is a separate task.",
  "mappings": [
    {"pattern": "stats/standard/mtgo/range_*w.json", "schema": "mtgo-range.schema.json"},
    {"pattern": "stats/standard/mtgo/decks_*w.json", "schema": "mtgo-decks.schema.json"},
    {"pattern": "stats/standard/mtgo/index.json", "schema": "mtgo-catalog.schema.json"},
    {"pattern": "stats/standard/mtgo/matchup_[0-9]*w.json", "schema": "mtgo-matchup.schema.json"},
    {"pattern": "stats/standard/mtgo/matchup_index.json", "schema": "mtgo-matchup-catalog.schema.json"},
    {"pattern": "stats/standard/mtgo/meta.json", "schema": "mtgo-meta.schema.json"},
    {"pattern": "stats/standard/mtgo/pickup/index.json", "schema": "mtgo-pickup-index.schema.json"},
    {"pattern": "stats/standard/mtgo/pickup/[0-9][0-9][0-9][0-9]-W[0-9][0-9].json", "schema": "mtgo-pickup-week.schema.json"}
  ]
}
