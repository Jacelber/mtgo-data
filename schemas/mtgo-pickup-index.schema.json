{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacelber.github.io/mtgo-data/schemas/mtgo-pickup-index.schema.json",
  "title": "MTGO Weekly Pickup catalog",
  "x-schema-version": "1.0.0",
  "type": "object",
  "required": ["schema_version", "format", "source", "weeks"],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/$defs/schemaVersion"},
    "format": {"enum": ["standard", "modern"]}, "source": {"const": "mtgo"},
    "weeks": {"type": "array", "items": {"type": "object", "required": ["week", "file", "start", "end", "existing_count", "new_count"], "properties": {
      "week": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"}, "file": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}\\.json$"},
      "start": {"type": "string", "format": "date"}, "end": {"type": "string", "format": "date"},
      "existing_count": {"type": "integer", "minimum": 0}, "new_count": {"type": "integer", "minimum": 0}
    }, "additionalProperties": false}}
  },
  "additionalProperties": false
}
