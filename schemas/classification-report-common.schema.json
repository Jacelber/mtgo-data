{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jacelber.github.io/mtgo-data/schemas/classification-report-common.schema.json",
  "x-schema-version": "1.0.0",
  "$defs": {
    "header": {
      "type": "object",
      "required": ["schema_version", "report_type", "format", "source", "scope", "event_count", "data_through"],
      "properties": {
        "schema_version": {"const": "1.0.0"},
        "report_type": {"type": "string", "minLength": 1},
        "format": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "source": {"const": "mtgo"},
        "scope": {"const": "all_available_events"},
        "event_count": {"type": "integer", "minimum": 0},
        "data_through": {"type": "string"}
      }
    },
    "identity": {
      "type": "object",
      "required": ["deck_id", "event_id", "event_name", "event_start", "source_file"],
      "properties": {
        "deck_id": {"type": "string", "pattern": "^[0-9a-f]{20}$"},
        "event_id": {"type": "string", "minLength": 1},
        "event_name": {"type": "string", "minLength": 1},
        "event_start": {"type": "string"},
        "source_file": {"type": "string", "pattern": "^data/[a-z0-9]+(?:-[a-z0-9]+)*/.+\\.json$"}
      }
    },
    "selected": {
      "type": ["object", "null"],
      "required": ["archetype_id", "archetype_name", "subtype_id", "subtype_name", "rule_id", "priority"],
      "properties": {
        "archetype_id": {"type": "string", "minLength": 1},
        "archetype_name": {"type": "string", "minLength": 1},
        "subtype_id": {"type": ["string", "null"]},
        "subtype_name": {"type": ["string", "null"]},
        "rule_id": {"type": "string", "minLength": 1},
        "priority": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["card", "zone", "actual_count", "min_count", "max_count", "exact_count"],
      "properties": {
        "card": {"type": "string", "minLength": 1},
        "zone": {"enum": ["any", "main", "side"]},
        "actual_count": {"type": "integer", "minimum": 0},
        "min_count": {"type": ["integer", "null"], "minimum": 0},
        "max_count": {"type": ["integer", "null"], "minimum": 0},
        "exact_count": {"type": ["integer", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "rule_match": {
      "type": "object",
      "required": ["archetype_id", "archetype_name", "subtype_id", "subtype_name", "rule_id", "priority", "evidence"],
      "properties": {
        "archetype_id": {"type": "string", "minLength": 1},
        "archetype_name": {"type": "string", "minLength": 1},
        "subtype_id": {"type": ["string", "null"]},
        "subtype_name": {"type": ["string", "null"]},
        "rule_id": {"type": "string", "minLength": 1},
        "priority": {"type": "integer", "minimum": 0},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}}
      },
      "additionalProperties": false
    },
    "basic_summary": {
      "type": "object",
      "required": ["record_count", "blocking"],
      "properties": {
        "record_count": {"type": "integer", "minimum": 0},
        "blocking": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "card": {
      "type": "object",
      "required": ["name", "quantity"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "quantity": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
